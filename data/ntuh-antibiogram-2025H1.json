    },
    "standards": {
      "bacteria": "CLSI M100 S34 (本院自 2025-07-01 起採用)",
      "anaerobe": "2011 CLSI Breakpoint agar dilution method",
      "candida": "CLSI M38 / M51S"
    },
    "footnotes": {
      "SAM": "ampicillin-sulbactam",
      "TZP": "piperacillin-tazobactam",
      "cefazolin_urine": "for uncomplicated UTIs",
      "cefazolin_other": "for infections other than uncomplicated UTIs",
      "tigecycline": "判讀依據 FDA",
      "SXT": "sulfamethoxazole-trimethoprim",
      "AMC": "amoxicillin-clavulanic acid",
      "colistin": "有效%依 (I) intermediate 之結果呈現",
      "gentamicin_high": "high-level gentamicin (enterococci synergy screen)",
      "candida_glabrata_fluconazole": "依 SDD% (dose-dependent susceptible) 呈現",
      "caspofungin": "CLSI 提醒不同實驗室檢驗結果會有差異，請小心判讀"
    },
    "WARNING": "本資料由報表圖片人工謄打，使用前務必對照台大原始報表核對，尤其臨床決策相關數值。分母數值小時百分比易受影響。"
  },

